---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ '/' | absolute_url }}</loc>
  </url>
  {% assign html_pages = site.pages | where_exp: "page", "page.url != '/sitemap.xml'" %}
  {% for page in html_pages %}
    {% unless page.url == '/' or page.url == '/robots.txt' or page.url contains '/assets/' or page.url contains '/staticfiles/' %}
  <url>
    <loc>{{ page.url | absolute_url }}</loc>
  </url>
    {% endunless %}
  {% endfor %}
  {% for note in site.notes %}
  <url>
    <loc>{{ note.url | absolute_url }}</loc>
  </url>
  <url>
    <loc>{{ note.pdf | absolute_url }}</loc>
  </url>
  {% endfor %}
  {% for item in site.coding %}
  <url>
    <loc>{{ item.url | absolute_url }}</loc>
  </url>
  {% endfor %}
</urlset>
